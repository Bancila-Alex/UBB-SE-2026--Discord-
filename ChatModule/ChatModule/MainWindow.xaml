<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="ChatModule.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ChatModule"
    xmlns:views="using:ChatModule.src.views"
    xmlns:viewModels="using:ChatModule.ViewModels"
    xmlns:srcViewModels="using:ChatModule.src.view_models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="ChatModule">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Background="#17153B">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#2E236C" Padding="14,18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Text="ChatModule"
                    Foreground="#C8ACD6"
                    FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3"
                    FontSize="24"
                    FontWeight="SemiBold"
                    Margin="2,0,0,18" />

                <Button
                    Grid.Row="1"
                    Content="Conversations"
                    Command="{x:Bind ViewModel.GoToConversationsCommand}"
                    Background="#433D8B"
                    Foreground="#C8ACD6"
                    BorderThickness="0"
                    CornerRadius="6"
                    Padding="12,10"
                    HorizontalAlignment="Stretch"
                    FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3"
                    FontSize="14"
                    Margin="0,0,0,8" />

                <Button
                    Grid.Row="2"
                    Content="Friends"
                    Command="{x:Bind ViewModel.GoToFriendsCommand}"
                    Background="#433D8B"
                    Foreground="#C8ACD6"
                    BorderThickness="0"
                    CornerRadius="6"
                    Padding="12,10"
                    HorizontalAlignment="Stretch"
                    FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3"
                    FontSize="14"
                    Margin="0,0,0,8" />

                <Button
                    Grid.Row="3"
                    Content="Profile"
                    Command="{x:Bind ViewModel.GoToProfileCommand}"
                    Background="#433D8B"
                    Foreground="#C8ACD6"
                    BorderThickness="0"
                    CornerRadius="6"
                    Padding="12,10"
                    HorizontalAlignment="Stretch"
                    FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3"
                    FontSize="14" />

                <Button
                    Grid.Row="5"
                    Content="Logout"
                    Command="{x:Bind ViewModel.LogoutCommand}"
                    Background="#17153B"
                    Foreground="#C8ACD6"
                    BorderBrush="#433D8B"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12,10"
                    HorizontalAlignment="Stretch"
                    FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3"
                    FontSize="14" />
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="#17153B" Padding="10">
            <ContentControl Content="{x:Bind ViewModel.CurrentPage, Mode=OneWay}" />
        </Border>
    </Grid>
</Window>
